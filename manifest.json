{
  "manifest_version": 3,
  "name": "X-FootPrint Cleaner",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://tuservidor.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"]
    }
  ]
}